# Database
# Local: both URLs can be the same.
# Supabase prod: DATABASE_URL = pooler (port 6543, ?pgbouncer=true); DIRECT_URL = direct (port 5432).
DATABASE_URL=postgresql://atomic:atomic@localhost:5432/atomic_habits
DIRECT_URL=postgresql://atomic:atomic@localhost:5432/atomic_habits

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
SESSION_SECRET=change-me-in-production

# Web
WEB_ORIGIN=http://localhost:4001
NEXT_PUBLIC_API_URL=http://localhost:4000

# Mail (Resend)
RESEND_API_KEY=re_your_api_key
RESEND_FROM=Atomic Habits <onboarding@resend.dev>
# Resend test sender only delivers to your account email — route all mail here.
RESEND_TO=conian2505@gmail.com
CONTACT_MAIL_TO=your@gmail.com

# Auth OTP
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60

NODE_ENV=development
