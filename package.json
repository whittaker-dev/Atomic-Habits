{
  "name": "atomic-habits",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm run --parallel dev",
    "dev:web": "pnpm --filter @atomic-habits/web dev",
    "dev:api": "pnpm --filter @atomic-habits/api dev",
    "build": "pnpm run -r build",
    "lint": "eslint . && pnpm --filter @atomic-habits/web lint",
    "typecheck": "pnpm run -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "db:deploy": "pnpm --filter @atomic-habits/api db:migrate:deploy && pnpm --filter @atomic-habits/api db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/web/**/*.{ts,tsx}": "pnpm --filter @atomic-habits/web exec next lint --fix --file",
    "*.{json,md,yml,yaml,css}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "msgpackr-extract"
    ]
  }
}
