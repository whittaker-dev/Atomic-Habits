{
  "name": "@atomic-habits/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @atomic-habits/shared build",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "db:generate": "node scripts/with-root-env.mjs prisma generate",
    "db:migrate": "node scripts/with-root-env.mjs prisma migrate dev",
    "db:pull": "node scripts/with-root-env.mjs prisma db pull",
    "db:seed": "node scripts/with-root-env.mjs tsx prisma/seed.ts",
    "db:studio": "node scripts/with-root-env.mjs prisma studio"
  },
  "dependencies": {
    "@atomic-habits/shared": "workspace:*",
    "@prisma/client": "^6.8.2",
    "argon2": "^0.44.0",
    "bullmq": "^5.53.0",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
