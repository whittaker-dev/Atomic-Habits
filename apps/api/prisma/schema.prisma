generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String               @map("password_hash")
  emailVerifiedAt     DateTime?            @map("email_verified_at")
  timezone            String               @default("UTC")
  totalXp             Int                  @default(0) @map("total_xp")
  level               Int                  @default(1)
  currentStreak       Int                  @default(0) @map("current_streak")
  bestStreak          Int                  @default(0) @map("best_streak")
  createdAt           DateTime             @default(now()) @map("created_at")
  emailOtps           EmailOtp[]
  completions         MissionCompletion[]
  missions            Mission[]
  kanbanTasks         KanbanTask[]
  englishSubmissions  EnglishSubmission[]

  @@map("users")
}

model EmailOtp {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  codeHash  String   @map("code_hash")
  purpose   String
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("email_otps")
}

model MissionCategory {
  id              String    @id @default(uuid())
  slug            String    @unique
  nameKey         String    @map("name_key")
  icon            String?
  defaultXpReward Int       @default(20) @map("default_xp_reward")
  sortOrder       Int       @default(0) @map("sort_order")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  missions        Mission[]

  @@map("mission_categories")
}

model Mission {
  id          String              @id @default(uuid())
  userId      String              @map("user_id")
  categoryId  String              @map("category_id")
  title       String
  xpReward    Int                 @default(20) @map("xp_reward")
  sortOrder   Int                 @default(0) @map("sort_order")
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  completions MissionCompletion[]
  category    MissionCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, categoryId])
  @@map("missions")
}

model MissionCompletion {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  missionId     String   @map("mission_id")
  completedDate DateTime @map("completed_date") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")
  mission       Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, completedDate])
  @@index([userId, completedDate])
  @@map("mission_completions")
}

enum KanbanColumn {
  todo
  in_progress
  done
}

model KanbanTask {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  title     String
  column    KanbanColumn @default(todo)
  sortOrder Int          @default(0) @map("sort_order")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, column, sortOrder])
  @@map("kanban_tasks")
}

enum EnglishChallengeType {
  vocabulary
  quiz
  phrase
}

model EnglishChallenge {
  id          String               @id @default(uuid())
  date        DateTime             @unique @db.Date
  type        EnglishChallengeType
  content     Json
  createdAt   DateTime             @default(now()) @map("created_at")
  submissions EnglishSubmission[]

  @@map("english_challenges")
}

model EnglishSubmission {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  challengeId String           @map("challenge_id")
  answers     Json
  score       Int
  xpAwarded   Int              @default(0) @map("xp_awarded")
  submittedAt DateTime         @default(now()) @map("submitted_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   EnglishChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId, submittedAt])
  @@map("english_submissions")
}

model PlanTrip {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  description   String   @default("")
  eyebrow       String   @default("")
  datesLabel    String   @default("") @map("dates_label")
  members       Json     @default("[]")
  transport     Json     @default("[]")
  accommodation Json     @default("{}")
  itinerary     Json     @default("{\"days\": []}")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("plan_trips")
}
