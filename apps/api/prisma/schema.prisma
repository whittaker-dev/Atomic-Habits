generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  timezone      String   @default("UTC")
  totalXp       Int      @default(0) @map("total_xp")
  level         Int      @default(1)
  currentStreak Int      @default(0) @map("current_streak")
  bestStreak    Int      @default(0) @map("best_streak")
  createdAt     DateTime @default(now()) @map("created_at")

  missions    Mission[]
  completions MissionCompletion[]

  @@map("users")
}

model MissionCategory {
  id             String   @id @default(uuid())
  slug           String   @unique
  nameKey        String   @map("name_key")
  icon           String?
  defaultXpReward Int     @default(20) @map("default_xp_reward")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  missions Mission[]

  @@map("mission_categories")
}

model Mission {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  title      String
  xpReward   Int      @default(20) @map("xp_reward")
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    MissionCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  completions MissionCompletion[]

  @@index([userId, categoryId])
  @@map("missions")
}

model MissionCompletion {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  missionId     String   @map("mission_id")
  completedDate DateTime @db.Date @map("completed_date")
  createdAt     DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId, completedDate])
  @@index([userId, completedDate])
  @@map("mission_completions")
}
